-- info-beamer globals available at runtime
globals = {
    "node",
}

read_globals = {
    "gl",
    "sys",
    "util",
    "resource",
    "NATIVE_WIDTH",
    "NATIVE_HEIGHT",
}

-- info-beamer callbacks receive args we may not use
unused_args = false

-- Max line length matching project convention
max_line_length = 99
